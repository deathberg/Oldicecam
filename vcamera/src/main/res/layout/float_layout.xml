<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="6dp">

    <ImageView
        android:id="@+id/main_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/app_label"
        android:scaleType="centerInside" />

    <GridLayout
        android:id="@+id/button_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="4"
        android:useDefaultMargins="false"
        android:visibility="gone">

        <Button android:id="@+id/butonf1" android:layout_width="50dp" android:layout_height="50dp" android:text="\u773c" />
        <Button android:id="@+id/butonf2" android:layout_width="50dp" android:layout_height="50dp" android:text="\u2191" />
        <Button android:id="@+id/butonf3" android:layout_width="50dp" android:layout_height="50dp" android:text="\u5634" />
        <Button android:id="@+id/butonf31" android:layout_width="50dp" android:layout_height="50dp" android:text="1" />
        <Button android:id="@+id/butonf4" android:layout_width="50dp" android:layout_height="50dp" android:text="\u2190" />
        <Button android:id="@+id/butonf5" android:layout_width="50dp" android:layout_height="50dp" android:text="\u6b63" />
        <Button android:id="@+id/butonf6" android:layout_width="50dp" android:layout_height="50dp" android:text="\u2192" />
        <Button android:id="@+id/butonf32" android:layout_width="50dp" android:layout_height="50dp" android:text="2" />
        <Button android:id="@+id/butonf7" android:layout_width="50dp" android:layout_height="50dp" android:text="\u64ad" />
        <Button android:id="@+id/butonf8" android:layout_width="50dp" android:layout_height="50dp" android:text="\u2193" />
        <Button android:id="@+id/butonf9" android:layout_width="50dp" android:layout_height="50dp" android:text="\u5faa" />
        <Button android:id="@+id/butonf33" android:layout_width="50dp" android:layout_height="50dp" android:text="3" />
        <Button android:id="@+id/butonf10" android:layout_width="50dp" android:layout_height="50dp" android:text="\u8f6c" />
        <Button android:id="@+id/butonf11" android:layout_width="50dp" android:layout_height="50dp" android:text="\u7ffb" />
        <Button android:id="@+id/butonf12" android:layout_width="50dp" android:layout_height="50dp" android:text="\u5173" />
        <Button android:id="@+id/butonf34" android:layout_width="50dp" android:layout_height="50dp" android:text="\u66ff" />
    </GridLayout>
</LinearLayout>
